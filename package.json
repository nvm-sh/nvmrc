{
	"name": "nvmrc",
	"version": "1.1.1",
	"description": "command-line tool to validate a `.nvmrc` file",
	"bin": "./nvmrc.mjs",
	"main": false,
	"types": "./index.d.mts",
	"exports": {
		".": {
			"types": "./index.d.mts",
			"default": "./index.mjs"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"prepack": "npmignore --auto --commentLines=autogenerated",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"prepublishOnly": "safe-publish-latest",
		"lint": "eslint .",
		"postlint": "tsc && attw -P",
		"pretest": "npm run lint",
		"tests-only": "NODE_OPTIONS='--no-warnings' c8 tape 'test/*.mjs'",
		"test": "npm run tests-only",
		"posttest": "npx npm@\">= 10.2\" audit --production",
		"version": "auto-changelog && git add CHANGELOG.md",
		"postversion": "auto-changelog && git add CHANGELOG.md && git commit --no-edit --amend && git tag -f \"v$(node -e \"console.log(require('./package.json').version)\")\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nvm-sh/nvmrc.git"
	},
	"keywords": [
		"nvm",
		"nvmrc",
		"validate"
	],
	"author": "Jordan Harband <ljharb@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/nvm-sh/nvmrc/issues"
	},
	"homepage": "https://github.com/nvm-sh/nvmrc#readme",
	"engines": {
		"node": "^20 || >= 22"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@ljharb/eslint-config": "^22.1.3",
		"@ljharb/tsconfig": "^0.3.2",
		"@types/tape": "^5.8.1",
		"auto-changelog": "^2.5.0",
		"c8": "^10.1.3",
		"encoding": "^0.1.13",
		"eslint": "^9.19.0",
		"jiti": "^0.0.0",
		"in-publish": "^2.0.1",
		"npmignore": "^0.3.5",
		"safe-publish-latest": "^2.0.0",
		"tape": "^5.9.0",
		"typescript": "next"
	},
	"testling": {
		"files": "test/*.js"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true
	},
	"publishConfig": {
		"ignore": [
			".attw.json",
			".github/workflows",
			"test",
			".nycrc",
			"eslint.config.mjs",
			"tsconfig.json"
		]
	}
}
